-- ============================================================================
-- SECTION 2: 多项式环 GF(3)[X]
-- ============================================================================

/-
================================================================================
CONCEPT: GF(3) 上的多项式
================================================================================

🎯 核心概念:
GF(3)[X] 是系数在 GF(3) 中的多项式环。
例如：f(X) = 2X² + X + 1 ∈ GF(3)[X]

💡 直观理解:
就像在整数上做多项式运算，只是系数只能取 0, 1, 2。

⚠️ 注意事项:
- 多项式相等当且仅当所有系数相等
- 次数 deg(f) 是最高非零项的指数
================================================================================
-/

-- GF(3) 上的多项式（使用 Mathlib 的 Polynomial）
abbrev GF3Poly := Polynomial GF3

namespace Polynomials

-- ============================================================================
-- EXAMPLE: 多项式求值
-- ============================================================================

/-- 定义多项式 f(X) = X + 2 -/
def f : GF3Poly := Polynomial.X + 2

/-- 定义多项式 g(X) = 2X² + 1 -/
def g : GF3Poly := 2 * Polynomial.X ^ 2 + 1

-- 计算 f(1) = 1 + 2 = 0 (mod 3)
theorem eval_f_at_1 : f.eval 1 = 0 := by
  simp [f, GF3]
  rfl

-- 计算 g(2) = 2×4 + 1 = 2×1 + 1 = 3 = 0 (mod 3)
-- 注意：2² = 4 = 1 (mod 3)
theorem eval_g_at_2 : g.eval 2 = 0 := by
  simp [g, GF3]
  rfl

-- ============================================================================
-- EXERCISE: 多项式运算
-- ============================================================================

-- 练习 2.1：计算 f + g（难度：⭐⭐）
theorem exercise_2_1 : (f + g).eval 0 = 0 := by
  sorry

-- 练习 2.2：计算 f × g 的次数（难度：⭐⭐⭐）
-- 提示：deg(f×g) = deg(f) + deg(g)（当 f,g ≠ 0 时）
theorem exercise_2_2 : (f * g).natDegree = 3 := by
  sorry

-- 练习 2.3：寻找多项式的根（难度：⭐⭐⭐）
-- 找出所有 a ∈ GF(3) 使得 f(a) = 0
theorem exercise_2_3 : ∀ a : GF3, f.eval a = 0 ↔ a = 1 := by
  sorry

end Polynomials


-- ============================================================================
-- SECTION 3: Frobenius 自同态
-- ============================================================================

/-
================================================================================
CONCEPT: Frobenius 自同态 x ↦ x³
================================================================================

🎯 核心概念:
对于有限域 GF(p)，Frobenius 映射 F(x) = xᵖ 是一个域自同态。
对于 GF(3)，F(x) = x³。

关键性质：
- F(x+y) = F(x) + F(y)（在特征 p 的域中）
- F(x×y) = F(x) × F(y)

💡 为什么重要？
Frobenius 是有限域理论的核心工具，在密码学中有广泛应用。

⚠️ 注意事项:
在 GF(3) 中，对于任意 a ∈ GF(3)，都有 a³ = a（费马小定理）
================================================================================
-/

namespace Frobenius

/-- Frobenius 映射：F(x) = x³ -/
def F (a : GF3) : GF3 := a ^ 3

-- ============================================================================
-- EXAMPLE: Frobenius 是恒等映射
-- ============================================================================
/-
在 GF(3) 中，Frobenius 映射是平凡的（恒等映射）。
这是因为对于任意 a ∈ {0,1,2}：
- 0³ = 0
- 1³ = 1
- 2³ = 8 = 2 (mod 3)

这是费马小定理的特例：a^(p-1) ≡ 1 (mod p) 对于 a ≠ 0
所以 a^p ≡ a (mod p)
-/ 
theorem frobenius_identity (a : GF3) : F a = a := by
  fin_cases a <;> simp [F, GF3]
  all_goals rfl

-- ============================================================================
-- EXERCISE: Frobenius 性质
-- ============================================================================

-- 练习 3.1：Frobenius 保持乘法（难度：⭐⭐）
theorem exercise_3_1_mul (a b : GF3) : F (a * b) = F a * F b := by
  sorry

-- 练习 3.2：Frobenius 保持加法（难度：⭐⭐）
-- 注意：这个性质只在特征 p 的域中成立
theorem exercise_3_2_add (a b : GF3) : F (a + b) = F a + F b := by
  sorry

end Frobenius


-- ============================================================================
-- CHALLENGE: GF(3²) 的构造
-- ============================================================================

/-
挑战：构造 GF(9) = GF(3²)

GF(9) 可以表示为 GF(3)[X]/(X²+1)，即 GF(3) 上多项式环模 X²+1。

要求：
1. 定义 GF(9) 的元素类型
2. 定义加法和乘法
3. 证明 GF(9) 是一个域

提示：
- X² + 1 在 GF(3) 上不可约
- GF(9) 的元素形如 a + bα，其中 α² = -1 = 2
-/ 

-- 挑战定义（待完成）
structure GF9 where
  a : GF3
  b : GF3
  deriving DecidableEq

def GF9.add (x y : GF9) : GF9 := 
  ⟨x.a + y.a, x.b + y.b⟩

def GF9.mul (x y : GF9) : GF9 := 
  ⟨x.a * y.a + 2 * x.b * y.b, x.a * y.b + x.b * y.a⟩

-- 挑战：证明乘法逆元存在
theorem challenge_GF9_field : ∀ x : GF9, x ≠ ⟨0, 0⟩ → ∃ y : GF9, 
  GF9.mul x y = ⟨1, 0⟩ := by
  sorry


-- ============================================================================
-- SOLUTIONS
-- ============================================================================

section Solutions

-- 练习 1.1 解答
theorem solution_1_1 (a b : GF3) : a + b = b + a := by
  fin_cases a <;> fin_cases b <;> simp [GF3.add]
  all_goals rfl

-- 练习 1.2 解答
theorem solution_1_2 (a b c : GF3) : (a * b) * c = a * (b * c) := by
  fin_cases a <;> fin_cases b <;> fin_cases c <;> simp [GF3.mul]
  all_goals rfl

-- 练习 1.3 解答
theorem solution_1_3 (a b : GF3) : a * b = b * a := by
  fin_cases a <;> fin_cases b <;> simp [GF3.mul]
  all_goals rfl

-- 练习 1.4 解答
theorem solution_1_4 (a b c : GF3) : a * (b + c) = a * b + a * c := by
  fin_cases a <;> fin_cases b <;> fin_cases c <;> simp [GF3.mul, GF3.add]
  all_goals rfl

-- 练习 1.5 解答
theorem solution_1_5 (a : GF3) (ha : a ≠ 0) : ∃ b : GF3, a * b = 1 := by
  fin_cases a
  · contradiction  -- a = 0 矛盾
  · use 1; rfl     -- a = 1, 逆元是 1
  · use 2; rfl     -- a = 2, 逆元是 2

end Solutions

end Sylva.Tutorial.GF3Advanced
