-- ============================================================================
-- SOLUTIONS
-- ============================================================================

section Solutions

-- 练习 1.1 解答
theorem solution_1_1 (a b : ℝ) : a^3 - b^3 = (a - b) * (a^2 + a*b + b^2) := by
  calc
    a^3 - b^3 = (a - b) * (a^2 + a*b + b^2) := by ring

-- 练习 1.2 解答
theorem solution_1_2 (a b : ℝ) (ha : 0 < a) (h : a < b) : a^2 < b^2 := by
  nlinarith [h, mul_pos ha (sub_pos.mpr h)]

-- 练习 1.3 解答
theorem solution_1_3 {φ : ℝ} (hφ : φ^2 = φ + 1) : φ^5 = 5*φ + 3 := by
  have h3 : φ^3 = 2*φ + 1 := by
    calc
      φ^3 = φ * φ^2 := by ring
      _ = φ * (φ + 1) := by rw [hφ]
      _ = φ^2 + φ := by ring
      _ = (φ + 1) + φ := by rw [hφ]
      _ = 2*φ + 1 := by ring
  have h4 : φ^4 = 3*φ + 2 := by
    calc
      φ^4 = φ * φ^3 := by ring
      _ = φ * (2*φ + 1) := by rw [h3]
      _ = 2*φ^2 + φ := by ring
      _ = 2*(φ + 1) + φ := by rw [hφ]
      _ = 3*φ + 2 := by ring
  calc
    φ^5 = φ * φ^4 := by ring
    _ = φ * (3*φ + 2) := by rw [h4]
    _ = 3*φ^2 + 2*φ := by ring
    _ = 3*(φ + 1) + 2*φ := by rw [hφ]
    _ = 5*φ + 3 := by ring

-- 练习 2.1 解答
theorem solution_2_1 (a b : ℝ) (h : a^2 + b^2 = 0) : a = 0 ∧ b = 0 := by
  have ha2 : a^2 ≥ 0 := sq_nonneg a
  have hb2 : b^2 ≥ 0 := sq_nonneg b
  have ha2_zero : a^2 = 0 := by
    linarith [h, ha2, hb2]
  have hb2_zero : b^2 = 0 := by
    linarith [h, ha2, hb2]
  have ha_zero : a = 0 := pow_eq_zero ha2_zero
  have hb_zero : b = 0 := pow_eq_zero hb2_zero
  exact ⟨ha_zero, hb_zero⟩

-- 练习 2.2 解答
theorem solution_2_2 (a b c d : ℝ) : (a^2 + b^2) * (c^2 + d^2) ≥ (a*c + b*d)^2 := by
  have h : (a^2 + b^2) * (c^2 + d^2) - (a*c + b*d)^2 = (a*d - b*c)^2 := by
    ring
  have h2 : (a*d - b*c)^2 ≥ 0 := sq_nonneg (a*d - b*c)
  linarith [h, h2]

-- 练习 3.2 解答
theorem solution_3_2 (x : ℕ) (h : x^3 = x) : x = 0 ∨ x = 1 := by
  by_cases hx : x ≤ 1
  · -- x ≤ 1，所以 x = 0 或 x = 1
    interval_cases x <;> simp
  · -- x > 1，证明不可能
    have h2 : x ≥ 2 := by omega
    have h3 : x^3 > x := by
      have h4 : x^2 > 1 := by nlinarith [h2]
      nlinarith [h2, h4]
    linarith

-- 练习 4.1 解答
theorem solution_4_1 (n : ℕ) : ∑ i in Finset.range (n + 1), (2 : ℕ)^i = 2^(n + 1) - 1 := by
  induction n with
  | zero =>
    simp
  | succ n ih =>
    rw [Finset.sum_range_succ, ih]
    ring_nf
    omega

-- 练习 5.1 解答思路
theorem solution_5_1 (a b c : ℝ) (ha : 0 < a) (hb : 0 < b) (hc : 0 < c) :
    (a + b + c) * (1/a + 1/b + 1/c) ≥ 9 := by
  field_simp
  nlinarith [sq_nonneg (a*b - b*c), sq_nonneg (b*c - c*a), sq_nonneg (c*a - a*b),
            sq_nonneg (a - b), sq_nonneg (b - c), sq_nonneg (c - a),
            mul_pos ha hb, mul_pos hb hc, mul_pos ha hc]

-- 练习 5.2 解答
theorem solution_5_2 (a b : ℝ) (ha : a ≠ 0) (hb : b ≠ 0) :
    ((a + b)^2 - (a - b)^2) / (4 * a * b) = 1 := by
  have h1 : (a + b)^2 - (a - b)^2 = 4 * a * b := by
    ring
  rw [h1]
  field_simp [ha, hb]

end Solutions

end Sylva.Tutorial.ProvingTechniques
